# PM Inquiry API Base URL
# Staging: https://pm-staging.jndsoft.co.kr/api/v1
# Production: https://hub.jndsoft.co.kr/api/v1
VITE_PM_API_BASE=https://pm-staging.jndsoft.co.kr/api/v1

# PM Public Inquiry API Key (X-API-Key header)
# Inject via Amplify console in production. Never expose in logs or public channels.
VITE_PM_INQUIRY_API_KEY=REPLACE_WITH_PM_INQUIRY_API_KEY
